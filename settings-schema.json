{
  "layout1": {
    "type": "layout",
    "pages": ["page-general", "page-interfaces", "page-appearance", "page-charts"],
    "page-general": {
      "type": "page",
      "title": "General",
      "sections": ["section-general-behaviour"]
    },
    "page-interfaces": {
      "type": "page",
      "title": "Interfaces",
      "sections": ["section-interface-selection", "section-interface-rows"]
    },
    "page-appearance": {
      "type": "page",
      "title": "Appearance",
      "sections": ["section-layout-display", "section-theme"]
    },
    "page-charts": {
      "type": "page",
      "title": "Charts",
      "sections": ["section-charts"]
    },
    "section-general-behaviour": {
      "type": "section",
      "title": "General Behaviour",
      "keys": ["sample-seconds", "rate-unit-mode", "show-header"]
    },
    "section-interface-selection": {
      "type": "section",
      "title": "Selection and Visibility",
      "keys": ["selection-mode", "preferred-interface", "include-tunnel-interfaces", "include-loopback-interfaces", "show-group-all", "aggregate-emphasis"]
    },
    "section-interface-rows": {
      "type": "section",
      "title": "Per-Interface Rows",
      "keys": ["interface-row-controls"]
    },
    "section-layout-display": {
      "type": "section",
      "title": "Layout and Display",
      "keys": ["display-density", "show-labels", "show-totals", "font-scale", "row-spacing", "content-alignment"]
    },
    "section-theme": {
      "type": "section",
      "title": "Theme",
      "keys": ["theme-mode", "manual-theme-action", "desklet-background-color", "row-background-color", "primary-text-color", "secondary-text-color", "rx-accent-color", "tx-accent-color"]
    },
    "section-charts": {
      "type": "section",
      "title": "Charts",
      "keys": ["show-sparklines", "history-length", "smoothing-mode"]
    }
  },
  "general-header": {
    "type": "header",
    "description": "General"
  },
  "sample-seconds": {
    "type": "spinbutton",
    "default": 1,
    "min": 0.25,
    "max": 10,
    "step": 0.25,
    "units": "s",
    "description": "Sampling interval",
    "tooltip": "How often the desklet should sample network counters. Lower values refresh faster but increase CPU wakeups."
  },
  "rate-unit-mode": {
    "type": "combobox",
    "default": "auto-bytes",
    "description": "Rate unit mode",
    "options": {
      "Automatic bytes per second": "auto-bytes",
      "Automatic bits per second": "auto-bits"
    }
  },
  "show-header": {
    "type": "switch",
    "default": true,
    "description": "Show desklet header",
    "tooltip": "Display the desklet title above the content."
  },
  "theme-header": {
    "type": "header",
    "description": "Theme"
  },
  "theme-mode": {
    "type": "combobox",
    "default": "dark",
    "description": "Theme mode",
    "options": {
      "Dark": "dark",
      "Light": "light",
      "Custom": "manual"
    }
  },
  "manual-theme-action": {
    "type": "combobox",
    "default": "none",
    "description": "Apply custom palette",
    "tooltip": "Load a curated custom palette or restore the default dark baseline colours.",
    "dependency": "theme-mode=manual",
    "options": {
      "No action": "none",
      "Reset to dark baseline": "reset-dark",
      "Reset to light baseline": "reset-light",
      "Ocean blue": "ocean-blue",
      "Forest mist": "forest-mist",
      "Amber glow": "amber-glow",
      "Crimson dusk": "crimson-dusk",
      "Pale sky": "pale-sky"
    }
  },
  "desklet-background-color": {
    "type": "colorchooser",
    "default": "rgb(24, 28, 36)",
    "description": "Desklet background colour",
    "dependency": "theme-mode=manual"
  },
  "row-background-color": {
    "type": "colorchooser",
    "default": "rgb(255, 255, 255)",
    "description": "Row background colour",
    "dependency": "theme-mode=manual"
  },
  "primary-text-color": {
    "type": "colorchooser",
    "default": "rgb(255, 255, 255)",
    "description": "Primary text colour",
    "dependency": "theme-mode=manual"
  },
  "secondary-text-color": {
    "type": "colorchooser",
    "default": "rgb(214, 220, 229)",
    "description": "Secondary text colour",
    "dependency": "theme-mode=manual"
  },
  "rx-accent-color": {
    "type": "colorchooser",
    "default": "rgb(115, 198, 255)",
    "description": "RX accent colour",
    "dependency": "theme-mode=manual"
  },
  "tx-accent-color": {
    "type": "colorchooser",
    "default": "rgb(255, 191, 87)",
    "description": "TX accent colour",
    "dependency": "theme-mode=manual"
  },
  "interfaces-header": {
    "type": "header",
    "description": "Interfaces"
  },
  "selection-mode": {
    "type": "combobox",
    "default": "auto",
    "description": "Interface selection mode",
    "options": {
      "Auto-detect": "auto",
      "Preferred interface": "preferred"
    }
  },
  "preferred-interface": {
    "type": "entry",
    "default": "",
    "description": "Preferred interface",
    "tooltip": "Interface name such as enp3s0 or wlo1. Used when selection mode is Preferred interface."
  },
  "include-tunnel-interfaces": {
    "type": "switch",
    "default": false,
    "description": "Include VPN and tunnel interfaces in auto selection",
    "tooltip": "Allow auto-detection to choose VPN interfaces such as tun0 or wg0 as the primary interface. VPN rows are shown by default unless you explicitly filter visible interfaces."
  },
  "include-loopback-interfaces": {
    "type": "switch",
    "default": false,
    "description": "Include loopback interfaces in row controls",
    "tooltip": "Show loopback interfaces such as lo in the per-interface row controls and allow them to appear as desklet rows when enabled there."
  },
  "interface-row-controls": {
    "type": "custom",
    "file": "InterfaceVisibilityWidget.py",
    "widget": "InterfaceVisibilityWidget",
    "state-key": "visible-interfaces",
    "display-key": "interface-display-settings",
    "reset-key": "reset-interface-request",
    "include-loopback-key": "include-loopback-interfaces",
    "default": "controls",
    "description": "Interfaces"
  },
  "interface-display-settings": {
    "type": "entry",
    "default": "",
    "description": "Interface display settings",
    "dependency": "selection-mode=__hidden__"
  },
  "visible-interfaces": {
    "type": "entry",
    "default": "",
    "description": "Visible interfaces state",
    "dependency": "selection-mode=__hidden__"
  },
  "show-group-all": {
    "type": "switch",
    "default": false,
    "description": "Show Group All Interfaces row",
    "tooltip": "Display the aggregate row for the monitored interfaces, including interfaces whose individual rows are currently hidden."
  },
  "aggregate-emphasis": {
    "type": "combobox",
    "default": "normal",
    "description": "Group All emphasis",
    "tooltip": "Choose whether the aggregate row should sit quietly in the background or stand out more clearly when shown.",
    "dependency": "show-group-all=true",
    "options": {
      "Subtle": "subtle",
      "Normal": "normal",
      "Prominent": "prominent"
    }
  },
  "reset-interface-request": {
    "type": "entry",
    "default": "",
    "description": "Reset interface request",
    "dependency": "selection-mode=__hidden__"
  },
  "layout-header": {
    "type": "header",
    "description": "Layout and Display"
  },
  "display-density": {
    "type": "combobox",
    "default": "comfortable",
    "description": "Display density",
    "tooltip": "Choose a coordinated layout preset, or switch to Manual to tune labels, totals, spacing, and chart visibility yourself.",
    "options": {
      "Compact": "compact",
      "Comfortable": "comfortable",
      "Detailed": "detailed",
      "Manual": "manual"
    }
  },
  "show-labels": {
    "type": "switch",
    "default": true,
    "description": "Show metric labels",
    "tooltip": "Display labels such as RX, TX, Total RX, and Total TX.",
    "dependency": "display-density=manual"
  },
  "show-totals": {
    "type": "switch",
    "default": true,
    "description": "Show session totals",
    "tooltip": "Display cumulative RX and TX totals for each visible row.",
    "dependency": "display-density=manual"
  },
  "font-scale": {
    "type": "spinbutton",
    "default": 1.0,
    "min": 0.8,
    "max": 2.0,
    "step": 0.1,
    "units": "x",
    "description": "Font scale",
    "tooltip": "Scale the desklet text without changing the desklet size.",
    "dependency": "display-density=manual"
  },
  "row-spacing": {
    "type": "spinbutton",
    "default": 10,
    "min": 4,
    "max": 24,
    "step": 1,
    "units": "px",
    "description": "Row spacing",
    "tooltip": "Adjust the space between interface rows.",
    "dependency": "display-density=manual"
  },
  "content-alignment": {
    "type": "combobox",
    "default": "left",
    "description": "Content alignment",
    "dependency": "display-density=manual",
    "options": {
      "Left": "left",
      "Centre": "center",
      "Right": "right"
    }
  },
  "charts-header": {
    "type": "header",
    "description": "Charts"
  },
  "show-sparklines": {
    "type": "switch",
    "default": true,
    "description": "Show sparkline charts",
    "tooltip": "Display history charts for RX and TX below each row.",
    "dependency": "display-density=manual"
  },
  "history-length": {
    "type": "spinbutton",
    "default": 60,
    "min": 10,
    "max": 120,
    "step": 5,
    "units": "samples",
    "description": "History length",
    "tooltip": "How many samples should be retained for each sparkline."
  },
  "smoothing-mode": {
    "type": "combobox",
    "default": "moving-average",
    "description": "Smoothing mode",
    "options": {
      "None": "none",
      "Moving average": "moving-average",
      "Exponential": "exponential"
    }
  }
}