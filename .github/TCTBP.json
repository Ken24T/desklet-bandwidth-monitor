{
  "schemaVersion": 1,
  "repository": {
    "mode": "local-first",
    "remoteName": "origin",
    "pullRequestsRequired": false,
    "pushRequiresRemote": true,
    "branchStrategy": {
      "default": "one-branch-per-phase",
      "allowSubBranchesForSignificantWork": true,
      "mergeCompletedPhaseToLocalMain": true,
      "createNextPhaseBranchAfterLocalMerge": true,
      "askBeforeRemotePushAfterPhaseMerge": true
    },
    "notes": [
      "This repo may operate without a remote during early development.",
      "Push steps are skipped when the configured remote does not exist.",
      "Completed implementation phases should normally merge to local main before any optional remote push."
    ]
  },
  "activation": {
    "triggers": ["ship", "ship please", "shipping", "tctbp", "prepare release", "handoff", "handoff please"],
    "caseInsensitive": true,
    "branchCommand": {
      "enabled": true,
      "pattern": "^branch\\s+(.+)$"
    }
  },
  "projectProfile": {
    "stack": "cinnamon-gjs-desklet",
    "primaryFiles": ["desklet.js", "metadata.json", "settings-schema.json", "stylesheet.css"],
    "lint": "./scripts/validate-desklet.sh",
    "format": "python3 -m json.tool metadata.json >/dev/null && python3 -m json.tool settings-schema.json >/dev/null",
    "test": "./scripts/validate-desklet.sh",
    "build": "./scripts/validate-desklet.sh",
    "package": "optional-manual-package-step",
    "versionFile": "metadata.json",
    "versionField": "version",
    "bootstrapRules": {
      "allowMissingChecks": false,
      "allowDocsOrInfrastructureShipWithoutBump": true,
      "requireExplicitUserConfirmationForCodeShipWithoutChecks": false
    }
  },
  "workflow": {
    "order": ["preflight", "test", "problems", "bump", "commit", "tag", "push"],
    "requireApproval": ["push"],
    "skipPushWhenRemoteMissing": true,
    "singleDeveloperDirectMerge": true,
    "implementationPhaseFlow": ["complete-phase-branch", "merge-to-local-main", "create-next-phase-branch", "ask-before-remote-push"]
  },
  "versioning": {
    "scheme": "semver",
    "patchEveryShip": true,
    "skipForChangeTypes": ["docs-only", "infrastructure-only"],
    "minorOnFirstShipOfBranch": true,
    "majorExplicitOnly": true,
    "defaultArtifact": "metadata.json"
  },
  "tagging": {
    "policy": "everyCommit",
    "skipWhenNoBump": true,
    "format": "{version}"
  }
}